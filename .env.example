# Шаблон переменных окружения — копировать в .env и заполнить реальными значениями
# .env в git не попадает (см. .gitignore)

# Ключ API 2ГИС (Каталог API) — нужен для парсинга юрфирм по городам
# Получить: https://dev.2gis.com/ (регистрация партнёра/разработчика)
GIS_2GIS_API_KEY=your_2gis_api_key_here
